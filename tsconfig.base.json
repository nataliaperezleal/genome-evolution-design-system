{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@genome-evolution/tokens": ["packages/tokens/src/index.ts"],
      "@genome-evolution/react": ["packages/react/src/index.ts"]
    }
  },
  "include": [
    ".storybook",
    "packages"
  ]
}
